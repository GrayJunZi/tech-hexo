
        /* ================= 核心变量定义 ================= */
        :root {
            --sidebar-width: hexo-config('layout.sidebar_width') || 260px;
            --top-bar-height: hexo-config('layout.top_bar_height') || 120px;
            --hero-height: hexo-config('layout.hero_height') || 60vh;
            --content-padding: hexo-config('layout.content_padding') || 60px;
            --border-radius: hexo-config('layout.border_radius') || 0px;

            /* 默认暗色主题 */
            --bg-sidebar: hexo-config('themes.dark.bg_sidebar') || #0a0a0c;
            --bg-main: hexo-config('themes.dark.bg_main') || #121214;
            --bg-content: hexo-config('themes.dark.bg_content') || #0f0f11; 
            --bg-panel: hexo-config('themes.dark.bg_panel') || #1a1a1c;
            --text-main: hexo-config('themes.dark.text_main') || #e0e0e0;
            --text-sub: hexo-config('themes.dark.text_sub') || #888888;
            --border: hexo-config('themes.dark.border') || rgba(255, 255, 255, 0.08);
            
            --color-orange: #d96a29; 
            --font-zh: 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', sans-serif;
            --font-en: 'Oswald', 'DIN', 'Helvetica Neue', Arial, sans-serif;
        }

        /* 亮色主题覆盖 */
        [data-theme='light'] {
            --bg-sidebar: hexo-config('themes.light.bg_sidebar') || #f0f0f2;
            --bg-main: hexo-config('themes.light.bg_main') || #ffffff;
            --bg-content: hexo-config('themes.light.bg_content') || #f5f5f7;
            --bg-panel: hexo-config('themes.light.bg_panel') || #e8e8ea;
            --text-main: hexo-config('themes.light.text_main') || #111111;
            --text-sub: hexo-config('themes.light.text_sub') || #666666;
            --border: hexo-config('themes.light.border') || rgba(0, 0, 0, 0.1);
        }

        /* ================= 基础重置 ================= */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: var(--font-zh); background-color: var(--bg-main); color: var(--text-main); overflow-x: hidden; border-radius: var(--border-radius); transition: background-color 0.3s, color 0.3s;}
        a { text-decoration: none; color: inherit; cursor: pointer; }
        ul { list-style: none; }
        button, input { border: none; outline: none; font-family: inherit; }

        /* 自定义滚动条 */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg-sidebar); }
        ::-webkit-scrollbar-thumb { background: #444; border-radius: 4px; border: 2px solid var(--bg-sidebar);}
        ::-webkit-scrollbar-thumb:hover { background: var(--color-orange); }

        /* ================= 全局动画 ================= */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes pulseGlow {
            0% { box-shadow: 0 0 0 0 rgba(217, 106, 41, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(217, 106, 41, 0); }
            100% { box-shadow: 0 0 0 0 rgba(217, 106, 41, 0); }
        }
        .animate-enter { animation: fadeInUp 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }

        /* ================= 整体布局 ================= */
        .layout-container { display: flex; min-height: 100vh; }

        /* ================= 左侧导航栏 (Sidebar) ================= */
        .sidebar {
            width: var(--sidebar-width); background-color: var(--bg-sidebar); border-right: 1px solid var(--border);
            display: flex; flex-direction: column; padding: 40px 0 0 0; z-index: 1000;
            position: fixed; height: 100vh; left: 0; top: 0;
            box-shadow: 5px 0 20px rgba(0,0,0,0.5);
            transition: width 0.3s, background-color 0.3s, border-color 0.3s;
        }

        .brand { display: flex; align-items: center; gap: 15px; padding: 0 30px; margin-bottom: 50px; cursor: pointer; transition: 0.3s; }
        .brand:hover { transform: translateX(5px); }
        .brand-icon { width: 24px; height: 32px; fill: #fff; }
        .brand-text { display: flex; flex-direction: column; }
        .brand-text h1 { font-size: 16px; font-weight: bold; font-family: var(--font-zh); letter-spacing: 2px; max-width: 170px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .brand-text span { font-size: 10px; color: var(--text-sub); font-family: var(--font-en); letter-spacing: 2px; }

        .nav-label { font-size: 10px; color: var(--text-sub); padding: 0 30px; margin-bottom: 15px; font-family: var(--font-en); letter-spacing: 1px; }
        .nav-label::before { content: '- '; }
        
        .nav-menu { display: flex; flex-direction: column; gap: 5px; margin-bottom: 40px; }
        .nav-item { cursor: pointer; transition: 0.3s; position: relative; overflow: hidden; height: 50px; }
        .nav-item a { display: flex; align-items: center; padding: 0 30px; gap: 15px; width: 100%; height: 100%; position: relative; z-index: 10; }
        .nav-item svg { width: 18px; height: 18px; fill: #666; transition: 0.3s; position: relative; z-index: 2;}
        .nav-item-text { display: flex; align-items: baseline; gap: 10px; position: relative; z-index: 2;}
        .nav-item-text .zh { font-size: 14px; font-weight: bold; color: var(--text-sub); transition: 0.3s; white-space: nowrap; }
        .nav-item-text .en { font-size: 10px; font-family: var(--font-en); color: #444; letter-spacing: 1px; transition: 0.3s; white-space: nowrap; }
        
        .nav-item::before { content: ''; position: absolute; left: 0; top: 0; width: 0; height: 100%; background: linear-gradient(90deg, rgba(217, 106, 41, 0.1) 0%, transparent 100%); transition: 0.4s ease; z-index: 1;}
        .nav-item::after { content: ''; position: absolute; left: 0; top: 0; width: 4px; height: 100%; background: var(--color-orange); transform: scaleY(0); transition: 0.3s; transform-origin: top; z-index: 2;}
        
        .nav-item.active::before, .nav-item:hover::before { width: 100%; }
        .nav-item.active::after, .nav-item:hover::after { transform: scaleY(1); }
        .nav-item.active svg, .nav-item:hover svg { fill: var(--color-orange); transform: scale(1.1); }
        .nav-item.active .zh, .nav-item:hover .zh { color: #fff; }
        .nav-item.active .en, .nav-item:hover .en { color: var(--color-orange); opacity: 0.7; }

        .sidebar-bottom { margin-top: auto; padding: 0 30px 30px 30px; display: flex; flex-direction: column; gap: 20px; }
        .user-info { display: flex; align-items: center; gap: 15px; cursor: pointer; transition: 0.3s;}
        .user-info:hover .avatar { animation: pulseGlow 1.5s infinite; }
        .avatar { width: 40px; height: 40px; background-color: #2a2a2c; background-size: cover; background-position: center; border-radius: 2px;}
        .user-name { font-size: 14px; font-weight: bold; font-family: var(--font-en); }
        .user-id { font-size: 10px; color: var(--text-sub); font-family: monospace; }
        .user-desc { font-size: 12px; color: var(--text-sub); line-height: 1.6; }
        
        .social-label { font-size: 11px; color: var(--text-sub); font-family: var(--font-en); margin-bottom: -10px; }
        .social-label::before { content: '// '; }
        .social-links { display: flex; gap: 12px; }
        .social-btn { 
            width: 32px; height: 32px; background: rgba(255,255,255,0.05); border: 1px solid var(--border);
            display: flex; justify-content: center; align-items: center; cursor: pointer; transition: 0.3s;
        }
        .social-btn svg { width: 16px; height: 16px; fill: #666; transition: 0.3s; }
        .social-btn:hover { background: var(--color-orange); border-color: var(--color-orange); transform: translateY(-3px);}
        .social-btn:hover svg { fill: #fff; }

        /* ================= 右侧主体内容 (Main Content) ================= */
        .main-wrapper { margin-left: var(--sidebar-width); width: calc(100% - var(--sidebar-width)); display: flex; flex-direction: column; min-height: 100vh; position: relative; overflow-y: auto; height: 100vh; transition: margin-left 0.3s, width 0.3s;}

        /* 顶栏 (Top Bar) */
        .top-bar {
            position: fixed; top: 0; right: 0; width: calc(100% - var(--sidebar-width)); z-index: 150; height: var(--top-bar-height); display: flex; align-items: center; justify-content: flex-end; padding: 0 40px; gap: 40px;
            background: linear-gradient(to bottom, var(--bg-main) 0%, rgba(10,10,12,0.6) 60%, transparent 100%);
            transition: width 0.3s, background 0.3s;
        }
        [data-theme='light'] .top-bar {
            background: linear-gradient(to bottom, var(--bg-main) 0%, rgba(255,255,255,0.6) 60%, transparent 100%);
        }

        .search-box { display: flex; align-items: center; background: rgba(255,255,255,0.1); border-radius: 4px; padding: 8px 15px; width: 240px; transition: 0.3s; border: 1px solid transparent;}
        .search-box:focus-within { border-color: var(--color-orange); background: rgba(255,255,255,0.15); }
        .search-box input { background: transparent; color: #fff; border: none; width: 100%; font-size: 12px; }
        .search-box input::placeholder { color: rgba(255,255,255,0.4); }
        .search-box svg { width: 16px; height: 16px; fill: #888; cursor: pointer; transition: 0.3s;}
        .search-box svg:hover { fill: var(--color-orange); }
        
        .top-links { display: flex; gap: 30px; font-size: 13px; font-weight: bold; color: #fff; }
        .top-links a { transition: 0.3s; position: relative; }
        .top-links a::after { content: ''; position: absolute; bottom: -5px; left: 0; width: 0; height: 2px; background: var(--color-orange); transition: 0.3s; }
        .top-links a:hover::after { width: 100%; }
        .top-links a:hover { color: var(--color-orange); }
        
        .sys-status { display: flex; align-items: center; gap: 10px; color: #fff;}
        .sys-status svg { width: 40px; height: 20px; stroke: #fff; fill: none; }
        .sys-text { display: flex; flex-direction: column; font-family: var(--font-en); font-size: 10px; line-height: 1.1; letter-spacing: 1px;}
        .sys-text .big { font-size: 14px; font-weight: bold; }

        /* 视图容器控制 */
        .view-section { display: none; flex-direction: column; flex: 1; padding-top: var(--top-bar-height); }
        .view-section.active { display: flex; }

        /* ================= 视图 1：首页 (Home View) ================= */
        .hero-section { position: relative; height: var(--hero-height); min-height: 450px; background-color: #111; display: flex; flex-direction: column; margin-top: calc(-1 * var(--top-bar-height)); }
        .hero-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: #1a1a1c; background-size: cover !important; background-position: center !important; transition: transform 10s linear; z-index: 1;}
        .hero-section:hover .hero-bg { transform: scale(1.05); }
        .hero-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(90deg, rgba(10,10,12,0.95) 0%, rgba(10,10,12,0.6) 40%, transparent 100%); z-index: 2; }

        .hero-content { position: relative; z-index: 10; flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 0 60px; margin-top: 50px;}
        .hero-tag { font-size: 11px; font-family: var(--font-en); color: var(--color-orange); letter-spacing: 3px; margin-bottom: 16px; }
        .hero-title { font-size: 42px; font-weight: bold; color: #fff; line-height: 1.2; margin-bottom: 16px; max-width: 600px; }
        .hero-subtitle { font-size: 14px; color: rgba(255,255,255,0.6); max-width: 500px; line-height: 1.6; margin-bottom: 30px; }
        .hero-btn {
            display: inline-flex; align-items: center; gap: 8px;
            border: 1px solid var(--color-orange); color: var(--color-orange);
            padding: 10px 24px; font-size: 12px; font-family: var(--font-en); letter-spacing: 2px;
            transition: 0.3s; width: fit-content; background: transparent;
        }
        .hero-btn:hover { background: var(--color-orange); color: #fff; }
        
        .hero-date {
            margin-top: 40px;
            background: rgba(0,0,0,0.4); padding: 15px 25px;
            border-left: 2px solid var(--color-orange); z-index: 10;
            text-align: left; font-family: var(--font-en);
            width: fit-content;
        }
        .hero-date-tag { font-size: 9px; letter-spacing: 2px; color: var(--color-orange); margin-bottom: 5px; }
        .hero-date-num { font-size: 28px; font-weight: bold; color: #fff; line-height: 1; }
        .hero-date-sub { font-size: 11px; color: rgba(255,255,255,0.5); }

        .home-content-section { background-color: var(--bg-content); color: var(--text-main); padding: 40px var(--content-padding); display: grid; grid-template-columns: 2fr 1fr; gap: 50px; flex: 1; transition: background-color 0.3s; }
        .section-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 25px; border-bottom: 1px solid var(--border); padding-bottom: 10px; }
        .section-title { font-size: 18px; font-weight: bold; display: flex; align-items: baseline; gap: 10px; color: var(--text-main);}
        .section-title span { font-size: 10px; font-family: var(--font-en); color: var(--text-sub); letter-spacing: 1px; font-weight: normal; }
        .section-title span::before { content: '/ '; }
        .section-more { font-size: 12px; color: var(--text-sub); font-weight: bold; cursor: pointer; transition: 0.2s; }
        .section-more:hover { color: var(--color-orange); letter-spacing: 1px;}

        /* 首页文章网格 (Post Grid) */
        .post-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
        @media screen and (max-width: 1200px) { .post-grid { grid-template-columns: 1fr; } }
        
        .post-card {
            position: relative; height: 200px; overflow: hidden; display: block;
            background: var(--bg-panel); border: 1px solid var(--border);
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .post-card:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,0,0,0.4); }
        .post-card-bg {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background-size: cover; background-position: center;
            transition: transform 0.4s;
            filter: brightness(0.5);
        }
        .post-card:hover .post-card-bg { transform: scale(1.05); filter: brightness(0.4); }
        .post-card-overlay {
            position: absolute; bottom: 0; left: 0; right: 0;
            padding: 20px; z-index: 2;
            background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);
        }
        .card-tag { font-size: 9px; font-family: var(--font-en); letter-spacing: 2px; color: var(--color-orange); text-transform: uppercase; display: block; margin-bottom: 6px; }
        .card-title { font-size: 16px; font-weight: bold; color: #fff; margin-bottom: 6px; line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .card-desc { font-size: 12px; color: rgba(255,255,255,0.6); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 8px; }
        .card-meta { display: flex; justify-content: space-between; align-items: center; font-size: 11px; color: rgba(255,255,255,0.5); font-family: var(--font-en); }
        .card-meta div { display: flex; align-items: center; gap: 4px; }

        .sidebar-right { display: flex; flex-direction: column; gap: 40px; }
        .widget { display: flex; flex-direction: column; gap: 10px; }
        
        /* 公告 Announce */
        .announce-list { display: flex; flex-direction: column; gap: 10px; }
        .announce-box {
            display: flex; gap: 15px; padding: 15px;
            background: var(--bg-panel); border: 1px solid var(--border);
            position: relative; overflow: hidden; transition: 0.3s;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        .announce-box:hover { border-color: var(--color-orange); transform: translateY(-3px); }
        .announce-watermark {
            position: absolute; right: -5px; top: -5px;
            font-size: 48px; font-weight: bold; font-family: var(--font-en);
            color: rgba(255,255,255,0.03); pointer-events: none; line-height: 1;
        }
        .announce-left { display: flex; flex-direction: column; align-items: center; gap: 5px; min-width: 40px; }
        .announce-left svg { width: 16px; height: 16px; fill: var(--color-orange); }
        .announce-date-big { font-size: 24px; font-weight: bold; font-family: var(--font-en); color: var(--color-orange); line-height: 1; }
        .announce-date-sub { font-size: 10px; color: var(--text-sub); font-family: var(--font-en); }
        .announce-right { flex: 1; min-width: 0; z-index: 2; }
        .announce-tag { display: inline-block; background: var(--color-orange); color: #fff; font-size: 10px; padding: 2px 8px; margin-bottom: 6px; border-radius: 2px; font-family: var(--font-en); letter-spacing: 1px;}
        .announce-title { font-size: 13px; font-weight: bold; color: var(--text-main); margin: 5px 0 4px; line-height: 1.3; }
        .announce-desc { font-size: 12px; color: var(--text-sub); line-height: 1.4; }

        /* 分类大纲 (Category Outline) */
        .cat-outline { padding: 5px 0; }
        .cat-outline .cat-list { list-style: none; padding: 0; margin: 0; }
        .cat-outline .cat-list-item { border-bottom: 1px solid var(--border); padding: 5px 0; }
        .cat-outline .cat-list-item a {
            display: flex; justify-content: space-between; align-items: center;
            padding: 8px 5px; font-size: 13px; color: var(--text-sub);
            transition: color 0.3s;
        }
        .cat-outline .cat-list-item a:hover { color: var(--color-orange); }
        .cat-outline .cat-list-link { font-weight: bold; }
        .cat-outline .cat-list-count { font-size: 11px; color: #555; font-family: var(--font-en); }
        .cat-outline .cat-list-child { list-style: none; padding-left: 15px; border-left: 1px solid var(--border); margin: 5px 0 5px 5px; }

        /* ================= 视图 2：文章详情页 (Article View) ================= */
        #view-article { background-color: var(--bg-main); color: var(--text-main); padding-top: var(--top-bar-height); transition: background-color 0.3s; }
        
        .breadcrumb { padding: 15px var(--content-padding); border-bottom: 1px solid var(--border); font-size: 10px; color: var(--text-sub); font-family: var(--font-en); letter-spacing: 1px; display: flex; align-items: center; gap: 8px;}
        .breadcrumb svg { width: 12px; height: 12px; fill: currentColor; cursor: pointer;}
        .breadcrumb span { cursor: pointer; transition: 0.2s; }
        .breadcrumb span:hover { color: var(--color-orange); }

        .article-layout { display: grid; grid-template-columns: 1fr 300px; gap: 60px; padding: 40px var(--content-padding); }
        
        .art-header { margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
        .art-title { font-size: 32px; font-weight: bold; margin-bottom: 15px; color: var(--text-main); letter-spacing: 1px; line-height: 1.4;}
        .art-title span { color: var(--color-orange); }
        
        .art-meta { display: flex; flex-wrap: wrap; gap: 20px; margin-top: 12px; font-size: 12px; color: var(--text-sub); font-family: var(--font-en); }
        .art-meta div { display: flex; align-items: center; gap: 6px; }
        .art-meta svg { width: 14px; height: 14px; fill: var(--text-sub); }

        /* 文章正文 Markdown 渲染 */
        .art-content { font-size: 15px; line-height: 1.9; color: var(--text-main); }
        .art-content h1, .art-content h2, .art-content h3,
        .art-content h4, .art-content h5, .art-content h6 { color: var(--text-main); line-height: 1.4; margin-top: 35px; margin-bottom: 12px; }
        .art-content h1 { font-size: 2em; border-bottom: 2px solid var(--color-orange); padding-bottom: 8px; }
        .art-content h2 { font-size: 1.5em; border-bottom: 1px solid var(--border); padding-bottom: 6px; color: #ffba52; }
        .art-content h3 { font-size: 1.25em; color: #fd6d6d; }
        .art-content p { margin: 16px 0; }
        .art-content a { color: var(--color-orange); border-bottom: 1px solid rgba(217,106,41,0.3); transition: 0.2s; }
        .art-content a:hover { border-color: var(--color-orange); }
        .art-content img { max-width: 100%; height: auto; display: block; margin: 20px auto; border: 1px solid var(--border); }
        .art-content blockquote { margin: 20px 0; padding: 12px 20px; border-left: 4px solid var(--color-orange); background: var(--bg-panel); color: var(--text-sub); }
        .art-content blockquote p { margin: 5px 0; }
        .art-content ul, .art-content ol { padding-left: 28px; margin: 16px 0; }
        .art-content li { margin-bottom: 6px; line-height: 1.7; }
        .art-content table { width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 14px; }
        .art-content th, .art-content td { border: 1px solid var(--border); padding: 8px 12px; text-align: left; }
        .art-content th { background: var(--bg-panel); color: var(--text-main); font-weight: bold; }
        .art-content :not(pre) > code { background: rgba(217, 106, 41, 0.15); color: #ff8c42; padding: 2px 6px; border-radius: 3px; font-size: 0.875em; font-family: monospace; }
        .art-content pre { background: #0d0d0f; border: 1px solid var(--border); border-radius: 4px; padding: 20px; overflow-x: auto; margin: 20px 0; position: relative; }
        .art-content pre code { background: none; color: #e0e0e0; padding: 0; font-size: 13px; font-family: monospace; }

        .copy-btn {
            position: absolute; top: 10px; right: 10px; padding: 4px 8px; font-size: 10px; font-family: var(--font-en);
            background: rgba(255,255,255,0.05); color: var(--text-sub); border: 1px solid var(--border);
            cursor: pointer; transition: 0.3s; z-index: 10;
        }
        .copy-btn:hover { background: var(--color-orange); color: #fff; border-color: var(--color-orange); }
        .copy-btn.success { background: #4caf50; color: #fff; border-color: #4caf50; }

        /* 文章侧栏 */
        .art-sidebar { min-width: 0; display: flex; flex-direction: column; gap: 30px; position: sticky; top: calc(var(--top-bar-height) + 20px); align-self: flex-start; height: fit-content; }
        .art-widget-title { font-size: 12px; font-weight: bold; font-family: var(--font-en); letter-spacing: 2px; color: var(--text-sub); margin-bottom: 15px; border-bottom: 1px solid var(--border); padding-bottom: 8px; }
        .art-widget-title span { color: var(--color-orange); margin-left: 8px; }

        /* 目录 TOC */
        .toc-list { font-size: 13px; line-height: 1.6; max-height: 60vh; overflow-y: auto; }
        .toc-list .toc { list-style: none; padding: 0; margin: 0; }
        .toc-list .toc-item { border-bottom: 1px solid var(--border); }
        .toc-list .toc-item a { display: block; padding: 8px 5px; color: var(--text-sub); transition: color 0.3s; }
        .toc-list .toc-item a:hover, .toc-list .toc-item.active a { color: var(--color-orange); }
        .toc-list .toc-child { list-style: none; padding-left: 15px; }

        /* 相关文章 */
        .related-list { display: flex; flex-direction: column; gap: 12px; }
        .rel-card { display: flex; gap: 12px; align-items: flex-start; transition: 0.3s; padding: 8px 0; border-bottom: 1px solid var(--border); }
        .rel-card:hover .rel-title { color: var(--color-orange); transform: translateX(5px); }
        .rel-img { width: 60px; height: 60px; object-fit: cover; flex-shrink: 0; border: 1px solid var(--border); }
        .rel-info { flex: 1; min-width: 0; }
        .rel-title { font-size: 13px; color: var(--text-main); margin: 4px 0; line-height: 1.3; transition: 0.3s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .rel-meta { font-size: 11px; color: var(--text-sub); font-family: var(--font-en); }

        /* 排序选项样式 */
        .sort-options { display: flex; gap: 20px; font-size: 12px; color: var(--text-sub); font-family: var(--font-en); align-items: center;}
        .sort-btn { cursor: pointer; display: flex; align-items: center; gap: 5px; transition: 0.3s; }
        .sort-btn:hover, .sort-btn.active { color: var(--color-orange); }
        .sort-btn .symbol { font-size: 14px; font-weight: bold; }
        .sort-btn.desc .symbol::after { content: ' ↓'; }
        .sort-btn.asc .symbol::after { content: ' ↑'; }

        /* 主题切换按钮 */
        .theme-toggle {
            width: 32px; height: 32px; background: rgba(255,255,255,0.05); border: 1px solid var(--border);
            display: flex; justify-content: center; align-items: center; cursor: pointer; transition: 0.3s;
            border-radius: 2px;
        }
        .theme-toggle:hover { background: var(--color-orange); border-color: var(--color-orange); }
        .theme-toggle svg { width: 16px; height: 16px; fill: var(--text-sub); transition: 0.3s; }
        .theme-toggle:hover svg { fill: #fff; }

        /* 音乐播放器样式 */
        .cassette-button-container { position: fixed; bottom: 20px; right: 20px; z-index: 2000; }
        .cassette-btn {
            background: var(--bg-panel); border: 1px solid var(--border); color: var(--text-main);
            padding: 10px 20px; cursor: pointer; display: flex; flex-direction: column; align-items: center;
            gap: 10px; transition: 0.3s; box-shadow: 0 5px 15px rgba(0,0,0,0.3); border-radius: var(--border-radius);
        }
        .cassette-btn:hover { border-color: var(--color-orange); transform: translateY(-3px); }

        /* ================= 底部版权区 (Footer) ================= */
        .app-footer {
            background-color: var(--bg-panel); border-top: 1px solid var(--border);
            padding: 20px 40px; display: flex; justify-content: space-between; align-items: center;
            font-size: 11px; font-family: var(--font-en); color: var(--text-sub); letter-spacing: 1px;
            margin-top: auto;
        }

        /* ================= 搜索结果样式 ================= */
        #local-search-result { background: var(--bg-panel); border: 1px solid var(--border); border-radius: 4px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); color: #fff; }
        #local-search-result .search-result-list { list-style: none; padding: 0; margin: 0; }
        #local-search-result .search-result-list li { padding: 12px; border-bottom: 1px solid var(--border); }
        #local-search-result .search-result-list a { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; color: #fff; text-decoration: none; transition: 0.2s; font-size: 14px; }
        #local-search-result .search-result-list a:hover { color: var(--color-orange); background: rgba(255,255,255,0.05); }
        #local-search-result .search-result { color: rgba(255,255,255,0.7); font-size: 13px; line-height: 1.5; margin-top: 5px; }
        #local-search-result .search-result .search-keyword { color: var(--color-orange); font-style: normal; font-weight: bold; }

        /* ================= 上下篇导航 (Post Nav) ================= */
        .post-nav {
            display: flex; justify-content: space-between; align-items: center;
            padding: 30px var(--content-padding); border-top: 1px solid var(--border);
            font-size: 13px; color: var(--text-sub); width: 100%; flex-wrap: nowrap;
        }
        .post-nav a { transition: color 0.3s; max-width: 45%; flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .post-nav a:hover { color: var(--color-orange); }
        .post-nav-center { font-family: var(--font-en); color: var(--border); font-size: 16px; margin: 0 20px; flex-shrink: 0; }
        #nav-prev { text-align: left; }
        #nav-next { text-align: right; }

        /* ================= 移动端适配 ================= */
        @media screen and (max-width: 768px) {
            .sidebar { position: fixed; left: -260px; transition: left 0.3s; z-index: 200; }
            .sidebar.open { left: 0; }
            .main-wrapper { margin-left: 0; width: 100%; }
            .top-bar { width: 100%; justify-content: space-between; padding: 0 20px; }
            .home-content-section { grid-template-columns: 1fr; padding: 20px; }
            .article-layout { grid-template-columns: 1fr; padding: 20px; }
            .art-sidebar { display: none; }
            .hero-content { padding: 0 20px; }
            .hero-title { font-size: 28px; }
            .hero-date { bottom: 20px; left: 20px; padding: 10px 15px; }
            .hero-date-num { font-size: 20px; }
            .post-nav { flex-direction: column; gap: 15px; align-items: flex-start; }
            .post-nav a { max-width: 100%; }
            .post-nav-center { display: none; }
        }

        /* ================= 文章版权 & 打赏 ================= */
        .article_copyright {
            padding: 15px 20px; margin: 20px 0;
            background: var(--bg-panel); border-left: 3px solid var(--color-orange);
            font-size: 13px; color: var(--text-sub); line-height: 1.7;
        }
        .article_copyright a { color: var(--color-orange); }
        .dashang {
            display: block; width: 56px; height: 56px; line-height: 56px;
            font-size: 20px; color: #fff; background: var(--color-orange);
            border-radius: 50%; text-align: center; margin: 20px auto;
            transition: 0.3s; cursor: pointer;
        }
        .dashang:hover { transform: scale(1.1); }
