/* ================= 街头潮流风 (Urban Streetwear UI / ZZZ Style) ================= */
[data-theme='street'] {
    --sidebar-width: 300px; /* 增加侧边栏宽度，提供呼吸感 */
    --bg-main: #e6e6e6; /* 水泥灰白底色，提供高对比度 */
    --bg-content: transparent;
    --bg-panel: #ffffff;
    --bg-sidebar: #000000; /* 绝对纯黑 */
    --text-main: #000000;
    --text-sub: #444444;
    --border: #000000;
    
    --street-yellow: #ccff00; /* 标志性潮流高亮黄/绿 */
    --street-black: #111111;
    --street-white: #f4f4f4;
    
    --font-zh: 'Noto Sans SC', 'PingFang SC', sans-serif;
    --font-en: 'Oswald', 'Impact', 'DIN Condensed', 'Arial Black', sans-serif;
}

/* --- 全局重置与背景 --- */
[data-theme='street'] body {
    background: var(--bg-main);
    /* 街头工业网点图背景 */
    background-image: radial-gradient(#aaa 1px, transparent 1px);
    background-size: 20px 20px;
    font-family: var(--font-zh);
}

[data-theme='street'] {
    /* 移除所有的柔和圆角与渐变过渡，强制采用硬切与方块感 */
    * { border-radius: 0 !important; }

    /* --- 1. 侧边栏重构 (Sidebar) --- */
    .sidebar {
        background: var(--street-black);
        border-right: none;
        box-shadow: 10px 0 0 rgba(0,0,0,0.1);
        padding: 0;
    }
    
    /* 警示带斜纹边缘 (内嵌于侧边栏右侧) */
    .sidebar::after {
        content: "";
        position: absolute;
        top: 0; right: 0; width: 12px; height: 100%;
        background: repeating-linear-gradient(
            -45deg,
            var(--street-yellow),
            var(--street-yellow) 10px,
            #000 10px,
            #000 20px
        );
        z-index: 10;
        pointer-events: none;
        border-left: 2px solid #333;
    }

    .brand { display: block; padding: 40px 20px 20px; background: #000; }
    .brand-text h1 {
        font-family: var(--font-en);
        font-size: 36px;
        color: var(--street-white);
        line-height: 1;
        text-transform: uppercase;
        margin-bottom: 20px;
        position: relative;
        z-index: 2;
        letter-spacing: 1px;
        word-wrap: normal;
        white-space: nowrap;
        max-width: none;
        overflow: visible;
    }
    .brand-text h1::after {
        content: "/// AUTHORIZED";
        display: block;
        font-size: 12px;
        letter-spacing: 3px;
        color: var(--street-yellow);
        margin-top: 10px;
        font-family: var(--font-en);
    }
    
    /* 导航项标签化 */
    .nav-label { 
        color: #666; border-bottom: 2px dashed #333; margin: 30px 15px 10px; 
        padding-bottom: 5px; font-weight: 900; font-family: var(--font-en);
    }
    .nav-label::before { content: "CAT_"; }
    
    .nav-item {
        background: transparent;
        border: none;
        border-left: 8px solid transparent;
        margin: 5px 25px 5px 15px; /* 右侧留白防止与警示带重叠 */
        padding: 12px 15px;
        transition: 0s; /* 移除平滑过渡，采用硬切 */
        position: relative;
        
        .zh { color: #fff; font-size: 18px; font-weight: 900; letter-spacing: 2px; }
        .en { color: #555; font-family: var(--font-en); font-size: 12px; text-transform: uppercase; }
        &::before, &::after { display: none; }
        
        &:hover, &.active {
            background: var(--street-yellow);
            border-left-color: #fff;
            transform: translateX(10px) rotate(-1deg);
            z-index: 10;
            box-shadow: 6px 6px 0 #000;
            .zh { color: #000; }
            .en { color: #000; font-weight: 900; }
            .nav-icon { filter: brightness(0); }
        }
    }

    /* 头像与信息 */
    .user-info { 
        margin-top: 30px; 
        padding: 20px 20px 20px 15px; 
        background: #000; 
        border-top: 5px solid #222; 
        gap: 20px;
    }
    .avatar-container {
        width: 60px;
        height: 60px;
        flex-shrink: 0;
        perspective: 1000px;
    }
    .avatar { 
        border: 4px solid var(--street-yellow); 
        width: 60px; 
        height: 60px; 
        transform: rotate(-5deg);
        transform-origin: top center;
        transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .user-info:hover .avatar {
        animation: streetAvatarSwing 1.5s ease-in-out;
    }
    @keyframes streetAvatarSwing {
        0% { transform: rotate(-5deg); }
        20% { transform: rotate(12deg); }
        40% { transform: rotate(-8deg); }
        60% { transform: rotate(5deg); }
        80% { transform: rotate(-6deg); }
        100% { transform: rotate(-5deg); }
    }
    .user-name { color: #fff; font-size: 20px; font-weight: 900; font-family: var(--font-en); text-transform: uppercase; margin-top: 10px; }
    .user-id { color: var(--street-yellow); font-family: monospace; font-size: 12px; font-weight: bold; }
    
    .social-btn {
        background: #222; border: 2px solid #555;
        &:hover { background: var(--street-yellow); border-color: #000; transform: translate(-3px, -3px); box-shadow: 4px 4px 0 #000; img { filter: brightness(0); } }
    }

    /* --- 2. 顶栏 (Top Bar) --- */
    .top-bar {
        background: transparent;
        border-bottom: 4px solid #000;
        padding-top: 15px;
        backdrop-filter: blur(10px);
    }
    .top-bar::before {
        content: "+++";
        position: absolute;
        left: 20px; top: 15px;
        color: #000; font-weight: 900; letter-spacing: 5px; font-size: 20px;
    }
    .search-box {
        background: #fff; border: 4px solid #000; box-shadow: 5px 5px 0 #000;
        padding: 8px 20px; font-weight: 900; color: #000;
        width: 220px;
        &:hover, &:focus-within, &.expanded { width: 260px; border-color: #000; background: var(--street-yellow); box-shadow: 8px 8px 0 #000; transform: translate(-2px, -2px); }
        input { font-weight: 900; font-size: 14px; }
        svg { fill: #000; }
    }
    .top-links a { color: #000; font-weight: 900; font-family: var(--font-en); text-transform: uppercase; border-bottom: 3px solid transparent; }
    .top-links a:hover { color: #000; background: var(--street-yellow); border-bottom: 3px solid #000; }
    .sys-text { color: #000; font-weight: 900; }

    /* --- 3. 巨幕区 (Hero Section - 核心视觉重构) --- */
    .hero-section {
        background: var(--bg-main);
        border: none; box-shadow: none;
        padding: calc(var(--top-bar-height) + 60px) 40px 60px; /* 补偿沉浸式顶部高度 */
        margin-top: calc(-1 * var(--top-bar-height)); /* 探入顶栏下方 */
        min-height: 500px;
        display: flex; flex-direction: column; justify-content: center;
        position: relative;
        overflow: hidden;
    }
    .hero-bg { 
        display: block; 
        filter: grayscale(100%) contrast(1.2) brightness(0.7);
        opacity: 0.6;
    } 
    
    /* 巨大背景文字水印 */
    .hero-section::before {
        content: "URBAN\AESTHETIC\00a0\00a0\00a0STREET";
        white-space: pre; position: absolute; top: -10%; left: -5%;
        font-family: var(--font-en); font-size: 18vw; line-height: 0.8;
        color: rgba(0,0,0,0.04); font-weight: 900; z-index: 0; transform: rotate(-5deg); pointer-events: none;
    }

    .hero-overlay { 
        display: block;
        background: linear-gradient(to right, rgba(230,230,230,0.9) 0%, rgba(230,230,230,0.4) 60%, transparent 100%);
    }

    .hero-content {
        position: relative; z-index: 2;
        background: #fff; border: 5px solid #000; padding: 50px;
        box-shadow: 15px 15px 0 #000;
        max-width: none; width: 100%;
        margin-top: 0;
        margin-bottom: 20px; /* 防止阴影被切断 */
        /* 右下角大尺寸硬切角 */
        clip-path: polygon(0 0, 100% 0, 100% calc(100% - 60px), calc(100% - 60px) 100%, 0 100%);
    }
    /* 补充切角的黄色封边色块 */
    .hero-content::after {
        content: ""; position: absolute; bottom: 0; right: 0;
        border-width: 0 0 60px 60px; border-style: solid;
        border-color: transparent transparent var(--street-yellow) transparent;
    }

    .hero-tag {
        background: #000; color: var(--street-yellow); display: inline-block; padding: 5px 20px;
        font-weight: 900; font-family: var(--font-en); letter-spacing: 2px;
        font-size: 16px; margin-bottom: 30px; text-transform: uppercase;
    }
    
    .hero-title {
        font-family: var(--font-en); font-size: 70px; color: #000;
        line-height: 1; text-transform: uppercase; margin-bottom: 25px;
        letter-spacing: -2px; font-weight: 900; max-width: 100%;
        word-wrap: break-word;
    }
    
    .hero-subtitle { color: #222; font-weight: 900; font-size: 16px; border-left: 8px solid var(--street-yellow); padding-left: 20px; max-width: 800px; line-height: 1.6; }
    
    .hero-btn {
        background: #000; color: var(--street-yellow) !important;
        font-family: var(--font-en); font-size: 20px; font-weight: 900;
        padding: 15px 40px; border: 4px solid #000; margin-top: 30px;
        display: inline-flex; align-items: center;
        transition: 0s; box-shadow: 6px 6px 0 var(--street-yellow);
        &:hover {
            background: var(--street-yellow); color: #000 !important;
            transform: translate(-4px, -4px); box-shadow: 10px 10px 0 #000;
        }
    }

    /* 独立出来的条形码/档案时间块 */
    .hero-date {
        position: absolute; right: 40px; top: calc(var(--top-bar-height) + 40px);
        background: var(--street-yellow); border: 4px solid #000;
        padding: 20px 30px; text-align: right; box-shadow: 10px 10px 0 #000;
        z-index: 5;
    }
    .hero-date-tag { color: #000; font-size: 12px; font-weight: 900; }
    .hero-date-num { font-size: 48px; color: #000; font-family: var(--font-en); font-weight: 900; line-height: 1; margin: 5px 0; }
    .hero-date-sub { display: none; }
    .hero-date::after {
        content: ""; display: block; width: 100%; height: 40px; margin-top: 15px;
        background-image: repeating-linear-gradient(to right, #000, #000 4px, transparent 4px, transparent 8px, #000 8px, #000 12px, transparent 12px, transparent 16px, #000 16px, #000 20px, transparent 20px, transparent 30px);
    }

    /* --- 4. 文章列表 (Post Cards) --- */
    .home-content-section { 
        background: transparent; 
        padding-top: 40px; 
        grid-template-columns: 2fr 1fr;
    }
    .section-title {
        font-family: var(--font-zh); font-weight: 900; font-size: 28px; color: #000;
        border-bottom: 5px solid #000; padding-bottom: 10px; margin-bottom: 40px;
        display: flex; align-items: center; gap: 15px;
    }
    .section-title span { font-family: var(--font-en); font-size: 14px; background: var(--street-yellow); color: #000; padding: 4px 15px; border: 2px solid #000; font-weight: 900; }

    .post-card { height: auto; margin-bottom: 50px; overflow: visible !important; }
    .post-card-inner {
        background: #fff; border: 4px solid #000; box-shadow: 12px 12px 0 #000;
        display: flex; flex-direction: column; transition: 0s;
        position: relative; overflow: visible;
    }
    /* 列表卡片胶带固定装饰 */
    .post-card-inner::before {
        content: ""; position: absolute; top: -15px; left: 50%; transform: translateX(-50%) rotate(-3deg);
        width: 100px; height: 30px; background: rgba(255,255,255,0.8);
        border: 1px solid #ddd; z-index: 10; box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    .post-card:hover .post-card-inner {
        transform: translate(-5px, -5px); box-shadow: 17px 17px 0 var(--street-yellow); border-color: #000;
    }
    .post-card-bg { height: 200px; border-bottom: 4px solid #000; filter: grayscale(100%) contrast(1.2); transition: filter 0.1s; position: relative; }
    .post-card:hover .post-card-bg { filter: grayscale(0%) contrast(1.1); }
    
    .post-card-overlay { position: relative; background: transparent; padding: 25px; display: block; color: #000; }
    .card-tag {
        background: var(--street-yellow); color: #000; font-family: var(--font-en); font-weight: 900;
        border: 3px solid #000; padding: 4px 15px; display: inline-block; margin-bottom: 15px;
        font-size: 14px; text-transform: uppercase;
    }
    .card-title { color: #000; font-size: 20px; font-weight: 900; margin-bottom: 15px; white-space: normal; line-height: 1.3; }
    .card-desc { color: #555; font-size: 14px; font-weight: bold; margin-bottom: 25px; line-height: 1.6; }
    .card-meta { border-top: 3px dashed #000; padding-top: 15px; color: #000; font-family: var(--font-en); font-weight: 900; font-size: 12px; }

    /* --- 5. 公告板 (Announce) - 警示标牌风格 --- */
    .announce-box {
        background: #000; border: 5px solid var(--street-yellow); color: #fff;
        padding: 30px; box-shadow: 12px 12px 0 #000; position: relative; overflow: hidden;
        transition: 0s;
        &:hover { background: var(--street-yellow); border-color: #000; color: #000; .announce-tag, .announce-desc { color: #000; } .announce-tag { border-color: #000; } }
    }
    .announce-box::before {
        content: "!"; position: absolute; right: 10px; top: -10px;
        font-family: var(--font-en); font-size: 120px; font-weight: 900; color: var(--street-yellow);
        line-height: 1; opacity: 0.3; transform: rotate(15deg);
    }
    .announce-box:hover::before { color: #fff; opacity: 0.5; }
    
    .announce-tag { background: #fff; color: #000; font-weight: 900; padding: 4px 12px; border: 2px solid transparent; font-family: var(--font-en); font-size: 12px; }
    .announce-date-big { color: var(--street-yellow); font-family: var(--font-en); font-size: 36px; font-weight: 900; line-height: 1.1; margin-top: 10px; }
    .announce-box:hover .announce-date-big { color: #000; }
    .announce-title { font-size: 18px; font-weight: 900; text-transform: uppercase; margin: 15px 0 10px; line-height: 1.3; }
    .announce-desc { font-weight: bold; color: #aaa; font-size: 13px; line-height: 1.5; }

    /* --- 6. 文章内页 (Article Layout) --- */
    #view-article { background: var(--bg-main); }
    .art-header {
        background: #fff; border: 5px solid #000; padding: 50px; box-shadow: 15px 15px 0 #000;
        margin-bottom: 50px; position: relative;
    }
    /* 工业印章 / 准星角标 */
    .art-header::before, .art-header::after { content: ""; position: absolute; width: 40px; height: 40px; border: 6px solid #000; }
    .art-header::before { top: 15px; left: 15px; border-right: none; border-bottom: none; }
    .art-header::after { bottom: 15px; right: 15px; border-left: none; border-top: none; }

    .art-title { font-family: var(--font-en); font-size: 48px; font-weight: 900; color: #000; text-transform: uppercase; line-height: 1.1; margin-bottom: 30px; letter-spacing: -1px; word-wrap: break-word; }
    .art-title span { background: var(--street-yellow); padding: 0 10px; }
    
    .art-meta { background: #000; color: #fff; padding: 15px; display: inline-flex; flex-wrap: wrap; gap: 20px; font-family: var(--font-en); font-weight: 900; font-size: 13px; border: 3px solid #000; }
    .art-meta-link { color: var(--street-yellow); }
    
    .art-content {
        background: #fff; border: 5px solid #000; padding: 50px; box-shadow: 15px 15px 0 #000; color: #000;
        h1, h2 { font-family: var(--font-zh); font-weight: 900; color: #000; border: none; text-transform: uppercase; }
        h1 { font-size: 2.2em; border-bottom: 6px solid #000; padding-bottom: 15px; }
        h2 { background: var(--street-yellow); display: inline-block; padding: 8px 20px; border: 4px solid #000; box-shadow: 6px 6px 0 #000; transform: rotate(-1deg); margin-top: 50px; font-size: 1.6em; }
        blockquote { background: #111; color: #fff; border: none; border-left: 15px solid var(--street-yellow); padding: 25px; font-weight: 900; font-size: 16px; margin: 30px 0; line-height: 1.6; }
        pre { background: #111; border: 4px solid #000; border-radius: 0; box-shadow: 8px 8px 0 var(--street-yellow); padding-top: 40px; position: relative; }
        pre::before { content: "SYS_TERMINAL_OUTPUT"; position: absolute; top: 0; left: 0; background: var(--street-yellow); color: #000; font-family: var(--font-en); font-weight: 900; font-size: 12px; padding: 4px 15px; border-bottom: 4px solid #000; border-right: 4px solid #000; }
        img { border: 5px solid #000; box-shadow: 10px 10px 0 #000; border-radius: 0; margin: 20px 0; max-width: 100%; }
        a { color: #000; background: var(--street-yellow); font-weight: 900; padding: 0 6px; border-bottom: 3px solid #000; text-decoration: none; display: inline-block; transform: translateY(-2px); box-shadow: 2px 2px 0 #000; transition: 0s; }
        a:hover { background: #000; color: var(--street-yellow); box-shadow: none; transform: translateY(0); }
    }

    /* --- 7. 侧边小部件 (Widgets) --- */
    .art-widget-title { background: #000; color: #fff; padding: 8px 20px; font-family: var(--font-en); font-weight: 900; font-size: 18px; display: inline-block; margin-bottom: 25px; text-transform: uppercase; border: 3px solid #000; box-shadow: 4px 4px 0 var(--street-yellow); }
    .rel-card { border: 4px solid #000; background: #fff; box-shadow: 6px 6px 0 #000; margin-bottom: 20px; transition: 0s; padding: 15px; }
    .rel-card:hover { background: var(--street-yellow); transform: translate(-3px, -3px); box-shadow: 9px 9px 0 #000; }
    .rel-title { font-weight: 900; color: #000; font-size: 15px; line-height: 1.4; }
    .rel-img { border: 3px solid #000; border-radius: 0; }
    
    .cat-list-item { border-bottom: 3px solid #000; padding: 12px 0; }
    .cat-list-link { font-weight: 900; color: #000; font-size: 16px; text-transform: uppercase; }
    .cat-list-count { background: var(--street-yellow); border: 3px solid #000; padding: 2px 10px; font-weight: 900; font-family: var(--font-en); margin-left: 10px; box-shadow: 2px 2px 0 #000; font-size: 12px; }

    /* --- 8. 滚动文字带 & 页脚 (Marquee Footer) --- */
    @keyframes marqueeX { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    .app-footer { position: relative; padding-top: 80px; padding-bottom: 40px; background: #000; color: #fff; border: none; font-family: var(--font-en); font-weight: 900; font-size: 14px; text-align: center; overflow: hidden; }
    .app-footer::before {
        content: "URBAN STREETWEAR /// DO NOT CROSS /// URBAN STREETWEAR /// DO NOT CROSS /// URBAN STREETWEAR /// DO NOT CROSS /// URBAN STREETWEAR /// DO NOT CROSS /// URBAN STREETWEAR /// DO NOT CROSS ///";
        position: absolute; top: 0; left: 0; width: 200%;
        background: var(--street-yellow); color: #000;
        font-family: var(--font-en); font-size: 24px; font-weight: 900;
        padding: 8px 0; border-bottom: 4px solid #000;
        white-space: nowrap; animation: marqueeX 15s linear infinite;
        pointer-events: none;
    }
    
    /* 工具栏与调色板高亮 */
    .toolbar-item { background: #fff; border: 4px solid #000; border-radius: 0; box-shadow: 4px 4px 0 #000; margin-bottom: 10px; transition: 0s; }
    .toolbar-item:hover { background: var(--street-yellow); transform: translate(-2px, -2px); box-shadow: 6px 6px 0 #000; svg { fill: #000; stroke: #000; } }
    .palette-item { border-radius: 0; border: 2px solid #000; }
    .palette-item[data-theme-style='street'].active, .palette-item[data-theme-style='street']:hover { background: var(--street-yellow); border: 2px solid #000; box-shadow: 4px 4px 0 #000; transform: translate(-2px, -2px); }

    /* 全局滚动条硬朗化 */
    ::-webkit-scrollbar { width: 12px; }
    ::-webkit-scrollbar-track { background: #fff; border-left: 3px solid #000; }
    ::-webkit-scrollbar-thumb { background: #000; border: 2px solid #fff; border-radius: 0; }
    ::-webkit-scrollbar-thumb:hover { background: var(--street-yellow); border-color: #000; }
}

/* --- 特有动效：突发故障跳动 (Glitch Hover) --- */
@keyframes streetGlitch {
    0% { transform: translate(0); }
    20% { transform: translate(-4px, 4px); }
    40% { transform: translate(-4px, -4px); }
    60% { transform: translate(4px, 4px); }
    80% { transform: translate(4px, -4px); }
    100% { transform: translate(0); }
}
[data-theme='street'] .brand-text h1:hover { 
    animation: streetGlitch 0.2s steps(2) infinite; 
    color: var(--street-yellow); 
    text-shadow: 4px 4px 0 #fff, -2px -2px 0 #ff0055; 
}
