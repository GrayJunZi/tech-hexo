.right-toolbar
    position fixed
    right -60px
    top 50%
    transform translateY(-50%)
    z-index 2000
    transition all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275)
    display flex
    align-items center
    
    &.active
        right 20px
    
    .toolbar-items
        background var(--bg-panel)
        border 1px solid var(--border)
        border-radius 30px
        padding 10px 5px
        display flex
        flex-direction column
        gap 15px
        box-shadow 0 10px 30px rgba(0,0,0,0.5)
        backdrop-filter blur(10px)

    .toolbar-item
        width 40px
        height 40px
        display flex
        justify-content center
        align-items center
        cursor pointer
        position relative
        border-radius 50%
        transition all 0.3s ease
        
        svg
            width 22px
            height 22px
            fill var(--text-sub)
            transition all 0.3s ease
            
        &:hover
            background rgba(217, 106, 41, 0.1)
            svg
                fill var(--color-orange)
                transform scale(1.1)
        
        &.disabled
            cursor not-allowed
            opacity 0.5
            svg
                fill #666 !important
            &:hover
                background transparent
            &::after
                content "非文章页不可用" !important

        &:active:not(.disabled)
            transform scale(0.9)

        &::after
            content attr(data-title)
            position absolute
            right 55px
            top 50%
            transform translateY(-50%) scale(0.8)
            background var(--bg-sidebar)
            color #fff
            padding 5px 12px
            border-radius 4px
            font-size 12px
            white-space nowrap
            opacity 0
            pointer-events none
            transition all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275)
            border 1px solid var(--border)
            box-shadow 0 5px 15px rgba(0,0,0,0.3)
            z-index 2001
            
        &:hover::after
            opacity 1
            right 60px
            transform translateY(-50%) scale(1)

    #tool-refresh:hover svg
        animation rotate360 1s ease-in-out
        
    #tool-mute
        .mute-container
            position relative
        .mute-slash
            position absolute
            top 50%
            left 50%
            width 0%
            height 2px
            background var(--color-orange)
            transform translate(-50%, -50%) rotate(-45deg)
            transition width 0.3s ease
            opacity 0
        
        &.muted
            svg
                opacity 0.5
            .mute-slash
                width 100%
                opacity 1

// 沉浸模式样式 - 平滑移动、动态宽度与性能优化
body.immersive-mode
    .sidebar
        transform translateX(-100%)

    .top-bar
        transform translateY(-100%)

    .art-sidebar
        transform translateX(100%) // 向右平移完全滑出
        opacity 0
        pointer-events none
        // 移除 width: 0 !important 等破坏动画和导致挤压的属性

    .post-nav, .app-footer, #rocket
        opacity 0
        pointer-events none

    .main-wrapper
        margin-left 0 !important
        width 100% !important

    .article-layout
        max-width 100%
        margin 0 !important
        grid-template-columns 1fr 0px !important // 平滑收缩侧边栏列宽
        gap 0 !important // 平滑收缩间距

// 为侧边栏增加固定宽度，防止在网格列缩小时被挤压变形
.art-sidebar
    width 300px
    flex-shrink 0

// 沉浸模式性能与平滑度优化
.sidebar, .top-bar, .art-sidebar, .main-wrapper, .article-layout, .art-content, .article-main
    will-change transform, width, margin, opacity, max-width, grid-template-columns, gap
    transition transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), 
               width 0.6s cubic-bezier(0.4, 0, 0.2, 1),
               margin 0.6s cubic-bezier(0.4, 0, 0.2, 1),
               opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
               max-width 0.6s cubic-bezier(0.4, 0, 0.2, 1),
               padding 0.6s cubic-bezier(0.4, 0, 0.2, 1),
               grid-template-columns 0.6s cubic-bezier(0.4, 0, 0.2, 1),
               gap 0.6s cubic-bezier(0.4, 0, 0.2, 1)
@keyframes rotate360
    from { transform: rotate(0deg) scale(1.1); }
    to { transform: rotate(360deg) scale(1.1); }

@media screen and (max-width: 1024px)
    .right-toolbar
        display none
