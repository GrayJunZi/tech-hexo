/* @theme p5 personal */
/* ==========================================================================
    女神异闻录5UI风格
   ========================================================================== */

[data-theme='personal'] {
    /* --- 核心色彩与排版体系 --- */
    --bg-main: #F4F3F0; /* 旧海报灰白 */
    --bg-sidebar: #E8E5DF; 
    --bg-panel: #FFFFFF;
    --text-main: #111111;
    --text-sub: #444444;
    --border: #111111; /* 极粗的黑线 */
    
    --color-red: #DA291C; /* 红色 */
    --color-black: #111111;
    
    --font-zh: 'Noto Sans SC', 'Heiti SC', 'Microsoft YaHei', sans-serif; /* 倾向于无衬线、粗重 */
    --font-en: 'Impact', 'Arial Black', 'Helvetica Neue', sans-serif;
    
    --sidebar-width: 280px;
    --top-bar-height: 100px;
    --content-padding: 60px;

    /* 粗犷的线条与硬朗的倒角 */
    --brutalist-border: 4px solid var(--color-black);
    --solid-shadow: 6px 6px 0px var(--color-black);
    --solid-shadow-red: 6px 6px 0px var(--color-red);
}

/* ================= 基础重置与全局骨骼布局 ================= */
[data-theme='personal'] body {
    background-color: var(--bg-main);
    color: var(--text-main);
    font-family: var(--font-zh);
    line-height: 1.6;
    letter-spacing: 0.5px;
    background-image: 
        linear-gradient(45deg, rgba(0,0,0,0.03) 25%, transparent 25%, transparent 75%, rgba(0,0,0,0.03) 75%, rgba(0,0,0,0.03)), 
        linear-gradient(45deg, rgba(0,0,0,0.03) 25%, transparent 25%, transparent 75%, rgba(0,0,0,0.03) 75%, rgba(0,0,0,0.03));
    background-size: 20px 20px;
    background-position: 0 0, 10px 10px;
}

/* 消除所有圆角 */
[data-theme='personal'] * {
    border-radius: 0 !important;
}

[data-theme='personal'] ::-webkit-scrollbar-thumb {
    background: var(--color-red);
    border: 2px solid var(--color-black);
}
[data-theme='personal'] ::-webkit-scrollbar-track {
    background: var(--bg-main);
    border-left: 2px solid var(--color-black);
}

/* ================= 侧边栏 (Sidebar) ================= */
[data-theme='personal'] .sidebar {
    background-color: var(--color-red);
    border-right: 6px solid var(--color-black);
    padding: 50px 0 30px 0;
}

[data-theme='personal'] .brand-text h1 {
    font-family: var(--font-en);
    font-size: 28px;
    font-weight: 900;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: 4px;
    text-shadow: 4px 4px 0 var(--color-black);
    transform: rotate(-2deg);
}

[data-theme='personal'] .brand-text span {
    color: #FFFFFF;
    background: var(--color-black);
    padding: 2px 8px;
    font-family: var(--font-en);
    font-weight: bold;
    letter-spacing: 2px;
}

[data-theme='personal'] .nav-label {
    background: var(--color-black);
    color: #FFFFFF;
    padding: 4px 10px;
    margin-left: 20px;
    display: inline-block;
    font-family: var(--font-en);
    font-size: 14px;
    text-transform: uppercase;
    transform: skewX(-10deg);
}
[data-theme='personal'] .nav-label::before { content: none; }

[data-theme='personal'] .nav-item {
    margin: 10px 20px;
    background: #FFFFFF;
    border: 3px solid var(--color-black);
    box-shadow: 4px 4px 0 var(--color-black);
    transition: all 0.1s;
    height: 48px;
}
[data-theme='personal'] .nav-item a {
    padding: 0 15px;
}
[data-theme='personal'] .nav-item .zh {
    color: var(--color-black);
    font-weight: 900;
    font-size: 16px;
}
[data-theme='personal'] .nav-item .en {
    color: var(--color-red);
    font-weight: 900;
    font-family: var(--font-en);
    text-transform: uppercase;
}
[data-theme='personal'] .nav-item:hover, [data-theme='personal'] .nav-item.active {
    transform: translate(4px, 4px);
    box-shadow: 0 0 0 var(--color-black);
    background: var(--color-red);
}
[data-theme='personal'] .nav-item:hover .zh, [data-theme='personal'] .nav-item.active .zh,
[data-theme='personal'] .nav-item:hover .en, [data-theme='personal'] .nav-item.active .en {
    color: #FFFFFF;
}

[data-theme='personal'] .avatar {
    border: 4px solid var(--color-black);
    box-shadow: var(--solid-shadow);
    filter: grayscale(100%) contrast(1.5);
    background-color: var(--color-red);
}

[data-theme='personal'] .user-name {
    color: #FFFFFF;
    text-shadow: 2px 2px 0 var(--color-black);
    font-size: 18px;
    font-weight: 900;
}
[data-theme='personal'] .user-id { color: var(--color-black); font-weight: bold; background: #FFFFFF; padding: 0 4px; }
[data-theme='personal'] .user-desc { color: #FFFFFF; font-weight: bold; }
[data-theme='personal'] .social-label { color: var(--color-black); background: #FFFFFF; padding: 2px 6px; font-weight: bold; }

[data-theme='personal'] .social-btn {
    background: #FFFFFF;
    border: 3px solid var(--color-black);
    box-shadow: 3px 3px 0 var(--color-black);
    transition: 0.1s;
}
[data-theme='personal'] .social-btn img { filter: none; }
[data-theme='personal'] .social-btn:hover {
    transform: translate(3px, 3px);
    box-shadow: 0 0 0 var(--color-black);
    background: var(--color-red);
}
[data-theme='personal'] .social-btn:hover img { filter: invert(1); }

/* ================= 顶栏结构 ================= */
[data-theme='personal'] .top-bar {
    background: var(--bg-main);
    border-bottom: 5px solid var(--color-black);
}

[data-theme='personal'] .search-box {
    background: #FFFFFF;
    border: 3px solid var(--color-black);
    box-shadow: 4px 4px 0 var(--color-black);
}
[data-theme='personal'] .search-box:focus-within {
    box-shadow: 4px 4px 0 var(--color-red);
    border-color: var(--color-red);
}

[data-theme='personal'] .top-links a {
    color: var(--color-black);
    font-family: var(--font-en);
    font-weight: 900;
    text-transform: uppercase;
    font-size: 16px;
    background: #FFFFFF;
    border: 2px solid var(--color-black);
    padding: 2px 10px;
    box-shadow: 2px 2px 0 var(--color-red);
    transition: 0.1s;
}
[data-theme='personal'] .top-links a:hover {
    transform: translate(2px, 2px);
    box-shadow: 0 0 0 var(--color-red);
    background: var(--color-red);
    color: #FFFFFF;
}

[data-theme='personal'] .sys-text {
    font-family: var(--font-en);
    color: var(--color-black);
}
[data-theme='personal'] .sys-text .big {
    font-size: 20px;
    font-weight: 900;
}

/* ================= 首页巨幕 (Hero Section) ================= */
[data-theme='personal'] .hero-section {
    background-color: var(--color-red);
    border: 6px solid var(--color-black);
    margin: 30px;
    box-shadow: 12px 12px 0 var(--color-black);
    position: relative;
    overflow: hidden;
}
/* 背景几何图形 */
[data-theme='personal'] .hero-section::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -10%;
    width: 200%;
    height: 200%;
    background: repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(0,0,0,0.1) 40px, rgba(0,0,0,0.1) 80px);
    z-index: 1;
    pointer-events: none;
}
[data-theme='personal'] .hero-section::after {
    content: "";
    position: absolute;
    bottom: -20px;
    right: 50px;
    width: 300px;
    height: 300px;
    background: var(--color-black);
    border-radius: 50% !important;
    z-index: 1;
    clip-path: polygon(0 0, 100% 0, 100% 50%, 0 50%);
    transform: rotate(-30deg);
}

[data-theme='personal'] .hero-overlay {
    background: transparent;
    z-index: 2;
    position: relative;
}

[data-theme='personal'] .hero-tag {
    background: var(--color-black);
    color: #FFFFFF;
    display: inline-block;
    padding: 4px 12px;
    font-size: 14px;
    font-family: var(--font-en);
    font-weight: 900;
    text-transform: uppercase;
    transform: skewX(-15deg);
}
[data-theme='personal'] .hero-title {
    font-family: var(--font-en);
    font-size: 48px;
    font-weight: 900;
    color: #FFFFFF;
    text-shadow: 4px 4px 0 var(--color-black);
    text-transform: uppercase;
    line-height: 1.1;
    margin-top: 10px;
}
[data-theme='personal'] .hero-subtitle {
    font-family: var(--font-zh);
    font-weight: 700;
    color: var(--color-black);
    background: #FFFFFF;
    padding: 10px 15px;
    border: 3px solid var(--color-black);
    box-shadow: 6px 6px 0 var(--color-black);
}
[data-theme='personal'] .hero-btn {
    background: #FFFFFF;
    color: var(--color-black) !important;
    border: 4px solid var(--color-black);
    padding: 12px 30px;
    font-family: var(--font-en);
    font-weight: 900;
    font-size: 16px;
    box-shadow: 6px 6px 0 var(--color-black);
    transition: 0.1s;
    text-transform: uppercase;
}
[data-theme='personal'] .hero-btn:hover {
    transform: translate(6px, 6px);
    box-shadow: 0 0 0 var(--color-black);
    background: var(--color-red);
    color: #FFFFFF !important;
}

[data-theme='personal'] .hero-date {
    border-left: none;
    background: var(--color-black);
    color: #FFFFFF;
    padding: 10px 20px;
    display: inline-block;
    transform: skewX(10deg);
}
[data-theme='personal'] .hero-date-tag { color: var(--color-red); font-weight: 900; }
[data-theme='personal'] .hero-date-num { color: #FFFFFF; font-size: 32px; font-weight: 900; }

/* ================= 主内容区域 ================= */
[data-theme='personal'] .section-header {
    border-bottom: 6px solid var(--color-black);
    margin-bottom: 20px;
}
[data-theme='personal'] .section-title {
    font-family: var(--font-zh);
    font-weight: 900;
    font-size: 24px;
    background: var(--color-black);
    color: #FFFFFF;
    display: inline-block;
    padding: 5px 15px;
}
[data-theme='personal'] .section-title span {
    color: var(--color-red);
    font-family: var(--font-en);
    font-weight: 900;
    text-transform: uppercase;
}

[data-theme='personal'] .post-card-inner {
    background: #FFFFFF;
    border: 4px solid var(--color-black);
    box-shadow: 8px 8px 0 var(--color-black);
    transition: 0.1s;
}
[data-theme='personal'] .post-card:hover .post-card-inner {
    transform: translate(4px, 4px);
    box-shadow: 4px 4px 0 var(--color-red);
    border-color: var(--color-red);
}
[data-theme='personal'] .post-card-bg {
    filter: grayscale(100%) contrast(1.2);
    border-bottom: 4px solid var(--color-black);
}
[data-theme='personal'] .post-card:hover .post-card-bg {
    filter: grayscale(0) contrast(1.2);
}
[data-theme='personal'] .post-card-overlay {
    background: transparent;
}
[data-theme='personal'] .card-title {
    color: var(--color-black);
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
}
[data-theme='personal'] .card-desc {
    color: var(--text-sub);
    font-weight: 700;
}
[data-theme='personal'] .card-tag {
    background: var(--color-red);
    color: #FFFFFF;
    padding: 2px 8px;
    display: inline-block;
    font-weight: 900;
    border: 2px solid var(--color-black);
}

[data-theme='personal'] .announce-box {
    background: #FFFFFF;
    border: 4px solid var(--color-black);
    box-shadow: 6px 6px 0 var(--color-black);
    transition: 0.1s;
}
[data-theme='personal'] .announce-box:hover {
    transform: translate(6px, 6px);
    box-shadow: 0 0 0 var(--color-black);
}
[data-theme='personal'] .announce-date-big {
    font-size: 32px;
    color: var(--color-black);
    text-shadow: 2px 2px 0 var(--color-red);
    font-family: var(--font-en);
    font-weight: 900;
}
[data-theme='personal'] .announce-tag {
    background: var(--color-black);
    border-radius: 0;
    font-size: 12px;
}

[data-theme='personal'] .cat-outline .cat-list-item {
    border-bottom: 2px solid var(--color-black);
}
[data-theme='personal'] .cat-outline .cat-list-link {
    font-weight: 900;
    color: #FFFFFF;
    text-transform: uppercase;
}
[data-theme='personal'] .cat-outline .cat-list-item a:hover {
    background: var(--color-red);
    color: #FFFFFF;
    padding-left: 10px;
}

/* ================= 文章详情页 ================= */
[data-theme='personal'] .art-header {
    border-bottom: 6px solid var(--color-black);
    padding-bottom: 20px;
}
[data-theme='personal'] .art-title {
    font-size: 36px;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--color-black);
}
[data-theme='personal'] .art-title span {
    background: var(--color-red);
    color: #FFFFFF;
    padding: 0 10px;
}

[data-theme='personal'] .art-content {
    font-size: 16px;
    color: var(--color-black);
    font-weight: 500;
}
[data-theme='personal'] .art-content h1,
[data-theme='personal'] .art-content h2,
[data-theme='personal'] .art-content h3 {
    font-weight: 900;
    text-transform: uppercase;
    color: var(--color-black);
    background: #FFFFFF;
    border: 4px solid var(--color-black);
    padding: 10px;
    box-shadow: 4px 4px 0 var(--color-red);
    display: inline-block;
    margin-top: 40px;
}
[data-theme='personal'] .art-content h1 { font-size: 28px; }
[data-theme='personal'] .art-content h2 { font-size: 24px; box-shadow: 4px 4px 0 var(--color-black); }
[data-theme='personal'] .art-content h3 { font-size: 20px; border-width: 2px; }

[data-theme='personal'] .art-content a {
    color: var(--color-red);
    font-weight: 900;
    border-bottom: 3px solid var(--color-red);
}
[data-theme='personal'] .art-content a:hover {
    background: var(--color-red);
    color: #FFFFFF;
}

[data-theme='personal'] .art-content blockquote {
    background: var(--color-black);
    color: #FFFFFF;
    border-left: 8px solid var(--color-red);
    padding: 20px;
    font-weight: bold;
    font-size: 18px;
    box-shadow: 6px 6px 0 rgba(0,0,0,0.2);
}
[data-theme='personal'] .art-content img {
    border: 4px solid var(--color-black);
    box-shadow: 8px 8px 0 var(--color-black);
    filter: grayscale(100%) contrast(1.2);
    transition: 0.3s;
}
[data-theme='personal'] .art-content img:hover {
    filter: grayscale(0) contrast(1.1);
    transform: translate(-4px, -4px);
    box-shadow: 12px 12px 0 var(--color-red);
}

[data-theme='personal'] .art-content pre {
    border: 4px solid var(--color-black);
    box-shadow: 6px 6px 0 var(--color-black);
    background: #111111;
}

[data-theme='personal'] .copy-btn {
    background: #FFFFFF;
    color: var(--color-black);
    border: 2px solid var(--color-black);
    font-weight: 900;
    text-transform: uppercase;
    box-shadow: 2px 2px 0 var(--color-black);
}
[data-theme='personal'] .copy-btn:hover {
    background: var(--color-red);
    color: #FFFFFF;
    transform: translate(2px, 2px);
    box-shadow: 0 0 0 var(--color-black);
}

[data-theme='personal'] .article_copyright {
    background: #FFFFFF;
    border: 4px solid var(--color-black);
    border-left: 12px solid var(--color-red);
    box-shadow: 6px 6px 0 var(--color-black);
    font-weight: bold;
    color: var(--color-black);
}

/* ================= 其他界面元素 ================= */
[data-theme='personal'] .toolbar-item {
    background: #FFFFFF;
    border: 3px solid var(--color-black);
    box-shadow: 4px 4px 0 var(--color-black);
    transition: 0.1s;
}
[data-theme='personal'] .toolbar-item:hover {
    transform: translate(4px, 4px);
    box-shadow: 0 0 0 var(--color-black);
    background: var(--color-red);
}
[data-theme='personal'] .toolbar-item:hover svg {
    fill: #FFFFFF;
}

[data-theme='personal'] .app-footer {
    border-top: 6px solid var(--color-black);
    background: var(--color-red);
    color: #FFFFFF;
    font-weight: 900;
    text-transform: uppercase;
}

[data-theme='personal'] #top-progress-bar {
    background: var(--color-red);
    height: 4px !important;
}
[data-theme='personal'] #top-progress-num {
    color: var(--color-red);
    font-weight: 900;
    font-size: 14px;
}
