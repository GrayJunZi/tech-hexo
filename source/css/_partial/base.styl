
/* ================= 基础重置 (Reset) ================= */
* { 
    margin: 0; 
    padding: 0; 
    box-sizing: border-box; 
}

body { 
    font-family: var(--font-zh); 
    background-color: var(--bg-main); 
    color: var(--text-main); 
    overflow-x: hidden; 
    border-radius: var(--border-radius); 
    transition: background-color 0.3s, color 0.3s;
}

a { 
    text-decoration: none; 
    color: inherit; 
    cursor: pointer; 
}

ul { 
    list-style: none; 
}

button, input { 
    border: none; 
    outline: none; 
    font-family: inherit; 
}

/* 自定义滚动条基础结构 */
::-webkit-scrollbar { 
    width: 8px; 
}
::-webkit-scrollbar-track { 
    background: var(--bg-sidebar); 
}
::-webkit-scrollbar-thumb { 
    border-radius: 4px; 
}

/* ================= 通用动画引擎 ================= */
@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

.fade-up-wait {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), 
                transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    pointer-events: none;
}
.fade-up-play {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
}

.fade-up-fast-wait {
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), 
                transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
}
.fade-up-fast-play {
    opacity: 1;
    transform: translateY(0);
}

.animate-enter { 
    opacity: 1;
}

/* ================= 骨架布局 (Layout Skeleton) ================= */
.layout-container { 
    display: flex; 
    min-height: 100vh; 
}

.sidebar {
    width: var(--sidebar-width); 
    display: flex; 
    flex-direction: column; 
    z-index: 1000;
    position: fixed; 
    height: 100vh; 
    left: 0; 
    top: 0;
}

.main-wrapper { 
    margin-left: var(--sidebar-width); 
    width: calc(100% - var(--sidebar-width)); 
    display: flex; 
    flex-direction: column; 
    min-height: 100vh; 
    position: relative; 
    overflow-y: auto; 
}

.top-bar {
    position: fixed; 
    top: 0; 
    left: var(--sidebar-width);
    right: 0; 
    z-index: 150; 
    height: var(--top-bar-height); 
    display: flex; 
    align-items: center; 
    justify-content: flex-end; 
    padding: 0 40px; 
    gap: 40px;
}

.view-section { 
    display: none; 
    flex-direction: column; 
    flex: 1; 
    padding-top: var(--top-bar-height); 
}
.view-section.active { 
    display: flex; 
}

/* ================= 组件结构 (Component Structure) ================= */
.brand { 
    display: flex; 
    align-items: center; 
    gap: 15px; 
    padding: 0 30px; 
    margin-bottom: 50px; 
    cursor: pointer; 
}
.brand-text { 
    display: flex; 
    flex-direction: column; 
}

.nav-menu { 
    display: flex; 
    flex-direction: column; 
    gap: 5px; 
    margin-bottom: 40px; 
}
.nav-item { 
    cursor: pointer; 
    position: relative; 
    overflow: hidden; 
    height: 50px; 
}
.nav-item a { 
    display: flex; 
    align-items: center; 
    padding: 0 30px; 
    gap: 15px; 
    width: 100%; 
    height: 100%; 
    position: relative; 
    z-index: 10; 
}
.nav-item-text { 
    display: flex; 
    align-items: baseline; 
    gap: 10px; 
    position: relative; 
    z-index: 2;
}

.sidebar-bottom { 
    margin-top: auto; 
    padding: 0 30px 30px 30px; 
    display: flex; 
    flex-direction: column; 
    gap: 20px; 
}
.user-info { 
    display: flex; 
    align-items: center; 
    gap: 15px; 
    cursor: pointer; 
    position: relative;
}
.avatar-container { 
    position: relative; 
    width: 40px; 
    height: 40px; 
    flex-shrink: 0; 
}

.social-links { 
    display: flex; 
    gap: 12px; 
}
.social-btn {
    width: 24px; 
    height: 24px; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    cursor: pointer; 
}

/* 搜索框结构 */
.search-box { 
    display: flex; 
    align-items: center; 
    border-radius: 4px; 
    padding: 8px 15px; 
    width: 140px;
    position: relative;
}
.search-filter-container {
    position: relative;
    margin-right: 10px;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    height: 100%;
}
.search-filter-panel {
    position: absolute;
    top: 30px; 
    left: 0; 
    border-radius: 4px;
    padding: 10px;
    display: none;
    flex-direction: column;
    gap: 8px;
    z-index: 200;
    width: 110px;
}
.search-box input { 
    background: transparent; 
    border: none; 
    width: 100%; 
    font-size: 12px; 
}

.top-links { 
    display: flex; 
    gap: 30px; 
}
.top-links a { 
    position: relative; 
}

.sys-status { 
    display: flex; 
    align-items: center; 
    gap: 20px; 
    height: 100%; 
    position: relative;
}
.sys-text { 
    display: flex; 
    flex-direction: column; 
    text-align: right; 
    min-width: 100px;
}

/* ================= 首页骨架 ================= */
.hero-section { 
    position: relative; 
    display: flex; 
    flex-direction: column; 
    overflow: hidden; 
}
.hero-bg { 
    position: absolute; 
    top: 0; 
    left: 0; 
    width: 100%; 
    height: 100%; 
    z-index: 1;
}
.hero-overlay { 
    position: absolute; 
    top: 0; 
    left: 0; 
    width: 100%; 
    height: 100%; 
    z-index: 2; 
}
.hero-content { 
    position: relative; 
    z-index: 10; 
    flex: 1; 
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
    padding: 0 60px; 
}
.hero-btn {
    display: inline-flex; 
    align-items: center; 
    gap: 8px;
    padding: 10px 24px; 
    width: fit-content; 
    background: transparent;
}
.hero-date {
    z-index: 10;
    text-align: left; 
    width: fit-content;
}

.home-content-section { 
    padding: 40px var(--content-padding); 
    display: grid; 
    grid-template-columns: 2fr 1fr; 
    gap: 50px; 
    flex: 1; 
}
.section-header { 
    display: flex; 
    justify-content: space-between; 
    align-items: flex-end; 
    margin-bottom: 25px; 
    padding-bottom: 10px; 
}
.section-title { 
    display: flex; 
    align-items: baseline; 
    gap: 10px;
}

/* 首页文章网格 */
.post-grid { 
    display: grid; 
    grid-template-columns: repeat(2, 1fr); 
    gap: 20px; 
}
@media screen and (max-width: 1200px) { 
    .post-grid { grid-template-columns: 1fr; } 
}

.post-card {
    position: relative; 
    height: 200px; 
    display: block;
    overflow: hidden; 
}
.post-card-inner {
    position: relative; 
    width: 100%; 
    height: 100%;
    overflow: hidden; 
}
.post-card-bg {
    position: absolute; 
    top: 0; 
    left: 0; 
    width: 100%; 
    height: 100%;
}
.post-card-overlay {
    position: absolute; 
    bottom: 0; 
    left: 0; 
    right: 0;
    padding: 20px; 
    z-index: 2;
}

.sidebar-right { 
    display: flex; 
    flex-direction: column; 
    gap: 40px; 
}
.widget { 
    display: flex; 
    flex-direction: column; 
    gap: 10px; 
}

.announce-list { 
    display: flex; 
    flex-direction: column; 
    gap: 10px; 
}
.announce-box {
    display: flex; 
    gap: 15px; 
    padding: 15px;
    position: relative; 
    overflow: hidden; 
}
.announce-watermark {
    position: absolute; 
    right: -5px; 
    top: -5px;
    pointer-events: none; 
    line-height: 1;
}
.announce-left { 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    gap: 5px; 
    min-width: 40px; 
}
.announce-right { 
    flex: 1; 
    min-width: 0; 
    z-index: 2; 
}

/* ================= 文章详情页骨架 ================= */
.breadcrumb { 
    padding: 15px var(--content-padding); 
    display: flex; 
    align-items: center; 
    gap: 8px;
}
.article-layout { 
    display: grid; 
    grid-template-columns: 1fr 300px; 
    gap: 60px; 
    padding: 40px var(--content-padding); 
}
.art-header { 
    margin-bottom: 30px; 
    padding-bottom: 20px; 
}
.art-meta { 
    display: flex; 
    flex-wrap: wrap; 
    gap: 20px; 
    margin-top: 12px; 
}
.art-meta div { 
    display: flex; 
    align-items: center; 
    gap: 6px; 
}

/* 文章正文 Markdown 结构 */
.art-content { 
    min-width: 0; 
}
.art-content img { 
    max-width: 100%; 
    height: auto; 
    display: block; 
    margin: 20px auto; 
}
.art-content blockquote { 
    margin: 20px 0; 
    padding: 12px 20px; 
}
.art-content ul, .art-content ol { 
    padding-left: 28px; 
    margin: 16px 0; 
}
.art-content table { 
    width: 100%; 
    border-collapse: collapse; 
    margin: 20px 0; 
}
.art-content pre { 
    border-radius: 4px; 
    padding: 20px; 
    overflow-x: auto; 
    margin: 20px 0; 
    position: relative; 
}

.copy-btn {
    position: absolute; 
    top: 10px; 
    right: 10px; 
    padding: 4px 8px; 
    cursor: pointer; 
    z-index: 10;
}

.art-sidebar { 
    min-width: 0; 
    display: flex; 
    flex-direction: column; 
    gap: 30px; 
    position: sticky; 
    top: calc(var(--top-bar-height) + 20px); 
    align-self: flex-start; 
    height: fit-content; 
    max-height: calc(100vh - var(--top-bar-height) - 40px); 
    overflow-y: auto; 
    padding-right: 5px;
    scrollbar-width: none;
    -ms-overflow-style: none;
}
.art-sidebar::-webkit-scrollbar { display: none; }

.toc-list { 
    max-height: 50vh; 
    overflow-y: auto;
    scrollbar-width: none; 
    -ms-overflow-style: none;
}
.toc-list::-webkit-scrollbar { display: none; }
.toc-list .toc { list-style: none; padding: 0; margin: 0; }
.toc-list .toc-child { list-style: none; padding-left: 15px; }

.related-list { 
    display: flex; 
    flex-direction: column; 
    gap: 12px; 
    max-height: 350px; 
    overflow-y: auto; 
    padding-right: 5px; 
    scrollbar-width: none; 
    -ms-overflow-style: none;
}
.related-list::-webkit-scrollbar { display: none; }
.rel-card { 
    display: flex; 
    gap: 12px; 
    align-items: flex-start; 
    padding: 8px 0; 
}
.rel-img { 
    width: 60px; 
    height: 60px; 
    object-fit: cover; 
    flex-shrink: 0; 
}
.rel-info { 
    flex: 1; 
    min-width: 0; 
}
.rel-tags { 
    display: flex; 
    gap: 4px; 
    overflow: hidden; 
    text-overflow: ellipsis; 
    white-space: nowrap; 
}

.sort-options { 
    display: flex; 
    gap: 20px; 
    align-items: center;
}
.sort-btn { 
    cursor: pointer; 
    display: flex; 
    align-items: center; 
    gap: 5px; 
}

.theme-toggle {
    width: 32px; 
    height: 32px; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    cursor: pointer; 
    border-radius: 2px;
}

/* 音乐控制 */
.music-controls {
    display: flex;
    flex-direction: row;
    gap: 12px;
    align-items: center;
    margin: 0;
    transform-origin: center;
}

.app-footer {
    padding: 20px 40px; 
    display: flex; 
    justify-content: space-between; 
    align-items: center;
    margin-top: auto;
}

.post-nav {
    display: flex; 
    justify-content: space-between; 
    align-items: center;
    padding: 30px var(--content-padding); 
    width: 100%; 
    flex-wrap: nowrap;
}
.post-nav a { 
    max-width: 45%; 
    flex: 1; 
    min-width: 0; 
    white-space: nowrap; 
    overflow: hidden; 
    text-overflow: ellipsis; 
}

.article_copyright {
    padding: 15px 20px; 
    margin: 20px 0;
}

#top-progress-container {
    position: fixed; 
    top: 0; 
    left: 0; 
    width: 100%; 
    height: 2px;
    z-index: 9999; 
    pointer-events: none; 
}
#top-progress-bar {
    height: 100%; 
    width: 0;
    position: relative;
}
#top-progress-num {
    position: absolute; 
    right: 0; 
    top: 5px;
    transform: translateX(50%);
}

.quber-tip {
    position: absolute;
    z-index: 9999;
    padding: 5px 8px;
    border-radius: 4px;
    font-size: 12px;
    display: none;
    pointer-events: none;
}
