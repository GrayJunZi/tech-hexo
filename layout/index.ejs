<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<%- partial('_partial/header') %>
<body>
<div id="top-progress-container">
    <div id="top-progress-bar">
        <span id="top-progress-num">0%</span>
    </div>
</div>
<script>
  window.THEME_CONFIG = {
    blog_path: "<%= theme.blog_path || '' %>",
    shortcutKey: <%= !!theme.shortcutKey %>,
    page_disable_shortcut: <%= !!page.disable_shortcut %>,
    highlight_on: <%= !!(theme.highlight && theme.highlight.on) %>,
    highlight_copy: <%= !!(theme.highlight && theme.highlight.copy) %>,
    i18n_search_empty: "<%= __('titles.search_empty') !== 'titles.search_empty' ? __('titles.search_empty') : '没有找到内容，更换下搜索词试试吧~' %>"
  };
</script>
<% if (theme.music_player && theme.music_player.enable) { %>
  <!-- 磁带播放器样式统一处理 -->
<% } %>
<div class="layout-container">
    <%- partial('_partial/sidebar') %>
    <%- partial('_partial/top-bar') %>
    <main class="main-wrapper">
        <div id="pjax-container" class="pjax">
            <div class="pjax-content">
                <%- partial('_partial/home') %>
            </div>
            <div class="pjax-glitch-layer layer-pink"></div>
            <div class="pjax-glitch-layer layer-cyan"></div>
        </div>
        <%- partial('_partial/app-footer') %>
    </main>
</div>
<%- fragment_cache('footer', function(){
    return partial('_partial/footer');
}) %>
</body>
</html>
