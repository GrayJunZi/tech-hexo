<aside class="sidebar">
    <div class="sidebar-close" id="sidebar-close">
        <svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
    </div>
    <a class="brand site_url" href="<%- url_for('/') %>">
        <svg class="brand-icon" viewBox="0 0 24 24">
            <g fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <path d="M7 7h10" />
                <path d="M7 12h10" />
                <path d="M7 16h6" />
            </g>
        </svg>
        <div class="brand-text">
            <h1><%- config.title || 'KEPHALA' %></h1>
            <span>- <%- config.subtitle || 'LOGOS' %> -</span>
        </div>
    </a>

    <div class="nav-label">NAVIGATION</div>
    <ul class="nav-menu">
        <%
        if (theme.menu && theme.menu.menus) {
            for (var key in theme.menu.menus) {
                var menu = theme.menu.menus[key];
                if (menu.on) {
                    var isActive = (menu.url === '/' && (path === 'index.html' || path === '')) || (menu.url !== '/' && ('/' + path).indexOf(menu.url) === 0);
                    // English fallback
                    var enName = menu.en || key.toUpperCase();
        %>
        <li class="nav-item <%- isActive ? 'active' : '' %>">
            <a class="site_url" href="<%- url_for(menu.url) %>">
                <img class="nav-icon" src="<%- url_for('/img/navigation/' + key + '.svg') %>" alt="<%= key %>">
                <div class="nav-item-text">
                    <span class="zh"><%- key %></span>
                    <span class="en"><%- enName %></span>
                </div>
            </a>
        </li>
        <% 
                }
            }
        } 
        %>
    </ul>

    <div class="nav-label">INFO</div>
    <div class="sidebar-bottom">
        <div class="user-info">
            <div class="avatar-container">
                <div class="avatar" style="background-image: url('<%- url_for(theme.avatar) %>')"></div>
                <div class="avatar glitch-layer layer-pink" style="background-image: url('<%- url_for(theme.avatar) %>')"></div>
                <div class="avatar glitch-layer layer-cyan" style="background-image: url('<%- url_for(theme.avatar) %>')"></div>
            </div>
            <div>
                <div class="user-name"><%- config.author || '这里在等待一个名字' %></div>
                <div class="user-id">#<%- new Date().getFullYear() %></div>
            </div>
        </div>
        <% 
        var sidebarDesc = config.description || (__('sidebar.description') !== 'sidebar.description' ? __('sidebar.description') : '计算机专业本科生，<br>每天不知道在忙什么。');
        var socialLabel = __('sidebar.social_label') !== 'sidebar.social_label' ? __('sidebar.social_label') : '你也能在以下地方遇到我';
        %>
        <div class="user-desc"><%- sidebarDesc %></div>

        <div class="social-label"><%- socialLabel %></div>
        <div class="social-links">
            <% if (theme.social) { %>
                <% for (var key in theme.social) { %>
                    <a class="social-btn" title="<%= key %>" href="<%- theme.social[key].url %>" target="_blank">
                        <img src="<%- url_for('/img/social/' + key + '.svg') %>" alt="<%= key %>">
                    </a>
                <% } %>
            <% } %>
        </div>
    </div>
</aside>
