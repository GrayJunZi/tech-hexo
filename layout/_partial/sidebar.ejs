<aside class="sidebar">
    <div class="sidebar-close" id="sidebar-close">
        <svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
    </div>
    <a class="brand site_url" href="<%- url_for('/') %>">
        <svg class="brand-icon" viewBox="0 0 24 24"><path d="M12 2L2 22h20L12 2zm0 4l6 14H6l6-14z"/><path d="M11 10h2v4h-2zm0 5h2v2h-2z"/></svg>
        <div class="brand-text">
            <h1><%- config.title || 'KEPHALA' %></h1>
            <span>- <%- config.subtitle || 'LOGOS' %> -</span>
        </div>
    </a>

    <div class="nav-label">NAVIGATION</div>
    <ul class="nav-menu">
        <%
        var navItems = [
            { name: '首页', en: 'HOME', url: '/', icon: '<path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>' },
            { name: '相册', en: 'PHOTO', url: theme.menu.menus.相册 ? theme.menu.menus.相册.url : '/photo', icon: '<path d="M22 16V4c0-1.1-.9-2-2-2H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2zm-11-4l2.03 2.71L16 11l4 5H8l3-4zM2 6v14c0 1.1.9 2 2 2h14v-2H4V6H2z"/>' },
            { name: '小说', en: 'NOVEL', url: theme.menu.menus.小说 ? theme.menu.menus.小说.url : '/novel', icon: '<path d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 4h5v8l-2.5-1.5L6 12V4z"/>' },
            { name: 'AI', en: 'AI', url: theme.menu.menus.Ai ? theme.menu.menus.Ai.url : '/AI', icon: '<path d="M19 8h-1.07A4.48 4.48 0 0 0 13 4.07V3h2V1h-2v1.07A4.49 4.49 0 0 0 9 2.07V1H7v2h2v1.07A4.48 4.48 0 0 0 6.07 8H5a3 3 0 0 0-3 3v6a3 3 0 0 0 3 3h14a3 3 0 0 0 3-3v-6a3 3 0 0 0-3-3zM8 14a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z m8 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>' }
            ];
        navItems.forEach(function(item) {
            var isActive = (item.url === '/' && (path === 'index.html' || path === '')) || (item.url !== '/' && ('/' + path).indexOf(item.url) === 0);
        %>
        <li class="nav-item <%- isActive ? 'active' : '' %>">
            <a class="site_url" href="<%- url_for(item.url) %>">
                <svg viewBox="0 0 24 24"><%- item.icon %></svg>
                <div class="nav-item-text">
                    <span class="zh"><%- item.name %></span>
                    <span class="en"><%- item.en %></span>
                </div>
            </a>
        </li>
        <% }); %>
    </ul>

    <div class="nav-label">INFO</div>
    <div class="sidebar-bottom">
        <div class="user-info">
            <div class="avatar-container">
                <div class="avatar" style="background-image: url('<%- url_for(theme.avatar) %>')"></div>
                <div class="avatar glitch-layer layer-pink" style="background-image: url('<%- url_for(theme.avatar) %>')"></div>
                <div class="avatar glitch-layer layer-cyan" style="background-image: url('<%- url_for(theme.avatar) %>')"></div>
            </div>
            <div>
                <div class="user-name"><%- config.author || '这里在等待一个名字' %></div>
                <div class="user-id">#<%- new Date().getFullYear() %></div>
            </div>
        </div>
        <div class="user-desc"><%- config.description || '计算机专业本科生，<br>每天不知道在忙什么。' %></div>

        <div class="social-label">你也能在以下地方遇到我</div>
        <div class="social-links">
            <a class="social-btn" title="GitHub" href="https://github.com/Sanqi-normal" target="_blank">
                <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12c0-5.52-4.48-10-10-10z"/></svg>
            </a>
            <a class="social-btn" title="Bilibili" href="https://space.bilibili.com/2140541511" target="_blank">
                <svg viewBox="0 0 24 24"><path d="M7 2l-1 2H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2h-3l-1-2H7zm1 6h8c.55 0 1 .45 1 1v4c0 .55-.45 1-1 1H8c-.55 0-1-.45-1-1V9c0-.55.45-1 1-1zm1 2v2h2v-2H9zm4 0v2h2v-2h-2z"/></svg>
            </a>
        </div>
    </div>
</aside>
