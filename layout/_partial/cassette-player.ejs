<!-- 简化版磁带按钮组件 -->
<div class="cassette-button-container">
    <button class="cassette-btn" id="playButton">
        <span class="btn-text">插入磁带【start】</span>
        <div class="tape-border">
            <div class="tape-segment segment-1"></div>
            <div class="tape-segment segment-2"></div>
            <div class="tape-segment segment-3"></div>
            <div class="tape-segment segment-4"></div>
        </div>
        <div class="led-indicator" id="statusLed"></div>
    </button>
</div>

<audio id="audioPlayer" loop>
    <!-- 替换为您的音乐文件路径 -->
    <source src="<%= theme.music_player.path || '/music/retro-future.mp3' %>" type="audio/mpeg">
    您的浏览器不支持音频元素。
</audio>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const playButton = document.getElementById('playButton');
    const audioPlayer = document.getElementById('audioPlayer');
    const statusLed = document.getElementById('statusLed');
    let isPlaying = false;
    AudioStart= new Audio('/music/cassette-eject-172757.mp3');
    AudioStop= new Audio('/music/tape-cassette-insert-172758.mp3');
    playButton.addEventListener('click', function() {
        if (!isPlaying) {
            // 播放音乐
            AudioStart.play();
            audioPlayer.play().then(() => {
                isPlaying = true;
                playButton.querySelector('.btn-text').textContent = '弹出磁带【stop】';
                playButton.classList.add('playing');
                statusLed.classList.add('active');
            }).catch(error => {
                console.error('播放失败:', error);
                alert('音乐播放失败，请检查音频文件路径或浏览器权限设置。');
            });
        } else {
            // 停止音乐
            AudioStop.play();
            audioPlayer.pause();
            audioPlayer.currentTime = 0;
            isPlaying = false;
            playButton.querySelector('.btn-text').textContent = '插入磁带【start】';
            playButton.classList.remove('playing');
            statusLed.classList.remove('active');
        }
    });
});
</script>