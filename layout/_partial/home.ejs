<%
function getCover(post) {
    if (post.cover) return url_for(post.cover);
    if (post.img) return url_for(post.img);
    var imgMatch = post.content.match(/<img[^>]+src="?([^"\s]+)"?[^>]*>/);
    if (imgMatch && imgMatch[1]) {
        return imgMatch[1];
    }
    
    // 动态匹配分类本地图：读取 /img/categories/[分类名].jpg
    if (post.categories && post.categories.length > 0) {
        var catName = post.categories.data[0].name;
        // 自动适配所有分类名，不再设限
        return url_for('/img/categories/' + catName + '.jpg');
    }

    return 'https://images.unsplash.com/photo-1605806616949-1e87b487cb2a?q=80&w=400&auto=format&fit=crop';
}

// Announcements (Top posts)
var topPosts = [];
site.posts.each(function(p) { if (p.top) topPosts.push(p); });
topPosts.sort(function(a, b) { return (b.top || 0) - (a.top || 0); });

// Post Selection
var postsSource = is_category() ? page.posts : site.posts;
var sortedPosts = postsSource.sort('-date').filter(function(p) { return !p.hidden; });

var latestPost = null;
var homePosts = [];

if (!is_category()) {
    latestPost = sortedPosts.length > 0 ? sortedPosts.data[0] : null;
    homePosts = sortedPosts.data.slice(1);
} else {
    homePosts = sortedPosts.data;
}
%>

<div id="view-home" class="view-section active">
    <% if (!is_category() && latestPost) { %>
    <section class="hero-section animate-enter">
        <div class="hero-bg" style="background-image: url('<%- getCover(latestPost) %>');"></div>
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-tag">· BLOG / LATEST -</div>
            <h1 class="hero-title"><%- latestPost.title %></h1>
            <p class="hero-subtitle">
                <% if (latestPost.excerpt) { %>
                    <%- strip_html(latestPost.excerpt).substring(0, 100) + '...' %>
                <% } else { %>
                    <%- strip_html(latestPost.content).substring(0, 100) + '...' %>
                <% } %>
            </p>
            <a class="hero-btn site_url" href="<%- url_for(latestPost.path) %>">VIEW MORE <span>></span></a>
            
            <div class="hero-date">
                <div class="hero-date-tag">LATEST UPDATE</div>
                <div class="hero-date-num"><%- date(latestPost.date, 'MM / DD') %></div>
                <div class="hero-date-sub"><%- date(latestPost.date, 'YYYY') %></div>
            </div>
        </div>
    </section>
    <% } %>

    <section class="home-content-section">
        <div class="main-column">
            <div class="section-header">
                <div class="section-title">
                    <% if (is_category()) { %>
                        分类：<%= page.category %> <span>POSTS</span>
                    <% } else { %>
                        最新文章 <span>LATEST POSTS</span>
                    <% } %>
                </div>
                <div class="sort-options">
                    <div class="sort-btn active desc" data-sort="date">DATE <span class="symbol"></span></div>
                    <div class="sort-btn" data-sort="title">TITLE <span class="symbol"></span></div>
                </div>
            </div>
            
            <div class="post-grid" id="home-post-grid">
                <% homePosts.forEach(function(post){ %>
                    <a class="post-card site_url animate-enter" href="<%- url_for(post.path) %>" data-date="<%- post.date.valueOf() %>" data-title="<%- post.title %>">
                        <div class="post-card-bg" style="background-image: url('<%- getCover(post) %>')"></div>
                        <div class="post-card-overlay">
                            <span class="card-tag"><%- post.categories && post.categories.length > 0 ? post.categories.data[0].name : '无分类' %></span>
                            <h3 class="card-title"><%- post.title %></h3>
                            <p class="card-desc">
                                <%- strip_html(post.excerpt || post.content).substring(0, 60) + '...' %>
                            </p>
                            <div class="card-meta">
                                <div><%- date(post.date, 'YYYY-MM-DD') %></div>
                                <div><svg style="width:12px; height:12px; fill:currentColor" viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg> <span><%- post.categories && post.categories.length > 0 ? post.categories.data[0].name : '随笔' %></span></div>
                            </div>
                        </div>
                    </a>
                <% }); %>
            </div>
        </div>

        <div class="sidebar-right">
            <% if (topPosts.length > 0) { %>
            <div class="widget">
                <div class="section-header"><div class="section-title">公告 <span>ANNOUNCEMENT</span></div></div>
                <div class="announce-list">
                    <% topPosts.slice(0,3).forEach(function(tp){ %>
                        <a class="announce-box site_url" href="<%- url_for(tp.path) %>">
                            <div class="announce-watermark">R.I.</div>
                            <div class="announce-left">
                                <div class="announce-date-big"><%- date(tp.date, 'DD') %></div>
                                <div class="announce-date-sub">/ <%- date(tp.date, 'MM') %></div>
                            </div>
                            <div class="announce-right">
                                <span class="announce-tag">置顶</span>
                                <h3 class="announce-title"><%- tp.title %></h3>
                                <p class="announce-desc"><%- strip_html(tp.excerpt || tp.content).substring(0, 40) %>...</p>
                            </div>
                        </a>
                    <% }); %>
                </div>
            </div>
            <% } %>

            <div class="widget">
                <div class="section-header"><div class="section-title">全部分类 <span>CATEGORIES</span></div></div>
                <div class="cat-outline">
                    <%
                    var childCategoryMap = {};
                    site.myCategories.forEach(function (category) {
                        if (category.parent) {
                            if (childCategoryMap[category.parent]) {
                                childCategoryMap[category.parent].push(category);
                            } else {
                                childCategoryMap[category.parent] = [category];
                            }
                        }
                    })
                    %>
                    <% function renderHomeCategory(category) { %>
                        <li class="cat-list-item">
                            <a class="site_url" href="<%- url_for(category.path) %>">
                                <span class="cat-list-link"><%= category.name %></span>
                                <span class="cat-list-count"><%= category.posts.length %></span>
                            </a>
                            <% if (childCategoryMap[category._id]) { %>
                                <ul class="cat-list-child">
                                    <% childCategoryMap[category._id].forEach(function (child) { %>
                                        <%= renderHomeCategory(child) %>
                                    <% }) %>
                                </ul>
                            <% } %>
                        </li>
                    <% } %>
                    <ul class="cat-list">
                        <% site.myCategories.forEach(function(category){ %>
                            <% if(!category.parent) { %>
                                <%= renderHomeCategory(category) %>
                            <% } %>
                        <% }) %>
                    </ul>
                </div>
            </div>
        </div>
    </section>
</div>
